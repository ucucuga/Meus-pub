# ── Server ──
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ── PostgreSQL (Prisma) ──
DATABASE_URL=postgresql://meus:meus_secret@localhost:5432/meus

# ── Redis (BullMQ job queues + rate limiting) ──
REDIS_URL=redis://localhost:6379

# ── JWT (API authentication) ──
JWT_SECRET=change_me_to_a_random_32_char_string
JWT_EXPIRES_IN=7d

# ── Telegram Mini App bot (@meus_escrow_bot) ──
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-here
# Optional: Telegram user ID for arbiter dispute alerts when arbiter has no linked User row
ARBITER_TELEGRAM_ID=

# ── TON network / indexer ──
TON_NETWORK=testnet
TON_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC
TON_API_KEY=your_toncenter_api_key

# ── Platform deployer wallet (contract deployment + automated ops 0x7–0x9) ──
DEPLOYER_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24

# ── Default arbiter address (burned into every escrow contract) ──
ARBITER_ADDRESS=UQAKFKgE5rjD6c7RfX9hIIpJljj2h5oMwkKgfOrAB_zJiucg

# ── Compiled contract code BOC (run `npm run export-boc` from repo root) ──
CONTRACT_CODE_PATH=./contract/meus.code.boc
